{
  "name": "teste-qa",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cy:open":"npx cypress open",
    "cy:run": "npx cypress run --config video=false --env allure=true --browser=chrome",
    "cy:run:e2e": "npx cypress run --spec \"cypress/e2e/ui/**/*.feature\" --config video=false --env allure=true --browser=chrome",
    "cy:run:api": "npx cypress run --spec \"cypress/e2e/api/**/*.cy.js\" --config video=false --env allure=true --browser=chrome",
    "cy:run:api:qa": "npm run cy:run:api -- --env targetEnv=qa",
    "cy:run:api:hml": "npm run cy:run:api -- --env targetEnv=hml",
    "cy:run:api:prod": "npm run cy:run:api -- --env targetEnv=prod",
    "allure:clear": "node -e \"['allure-results','allure-report'].forEach((dir) => require('fs').rmSync(dir, { recursive: true, force: true }))\"",
    "allure:generate": "node scripts/allure-runner.js generate allure-results --clean -o allure-report",
    "allure:open": "node scripts/allure-runner.js open allure-report"
  },
  "cypress-cucumber-preprocessor": {
    "screenshotsFolder": "cypress/screenshots",
    "messages": {
      "enabled": true
    },
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-results.json"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.37.0",
    "allure-cypress": "^3.5.0",
    "cypress": "^15.11.0",
    "cypress-plugin-api": "^2.11.2"
  }
}